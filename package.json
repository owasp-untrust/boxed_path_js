{
  "name": "untrust-ts",
  "version": "1.1.0",
  "description": "A secure path and FS enforcement framework for server-side JS/TS environments (Node.js, Deno, Bun) to prevent Path Traversal.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "bin": {
    "untrust-ts-scan": "./dist/scripts/run-security-scan.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "security-check": "node --loader ts-node/esm ./scripts/run-security-scan.ts",
    "prebuild": "npm run security-check",
    "build": "tsc",
    "pretest": "npm run security-check",
    "test": "node --loader ts-node/esm tests/validator.test.ts",
    "predemo": "npm run security-check",
    "demo": "node --loader ts-node/esm demo.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "security",
    "path-traversal",
    "enforcement",
    "secure-fs",
    "nodejs",
    "deno",
    "bun",
    "server-side"
  ],
  "author": "Or Bibi",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}